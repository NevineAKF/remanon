{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "remanon/artifact/triage/v1",
  "title": "TriageArtifact",
  "description": "Output envelope produced by the Triage agent.",
  "type": "object",
  "required": ["artifact_id", "agent", "version", "payload"],
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this artifact instance."
    },
    "agent": {
      "type": "string",
      "const": "triage"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "required": ["severity", "category", "summary", "routing"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "summary": {
          "type": "string",
          "maxLength": 512
        },
        "routing": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["correlator", "hunter", "topology", "reporter"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "hbm3_handle": {
          "type": ["string", "null"],
          "description": "Opaque handle to a resident HBM3 region, null when running CPU-only."
        }
      }
    }
  }
}
